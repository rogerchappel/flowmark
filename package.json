{
  "name": "flowmark",
  "version": "0.1.0",
  "description": "A local-first workflow linter and outline renderer for agent runbooks.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "flowmark": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "docs/PRD.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && node scripts/lint.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "validate": "bash scripts/validate.sh"
  },
  "keywords": [
    "agent",
    "workflow",
    "runbook",
    "markdown",
    "yaml",
    "cli",
    "lint"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "mdast-util-from-markdown": "^2.0.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/flowmark.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/flowmark/issues"
  },
  "homepage": "https://github.com/rogerchappel/flowmark#readme"
}
